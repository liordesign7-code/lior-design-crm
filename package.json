const express = require('express');
const router = express.Router();
const admin = require('firebase-admin');
const fs = require('fs');

// 🔥 טעינת Firebase מה־secret file
let serviceAccount;

try {
  serviceAccount = JSON.parse(
    fs.readFileSync('/etc/secrets/firebase.json', 'utf8')
  );
} catch (err) {
  console.error('❌ Failed to load firebase.json', err);
}

// 🔥 אתחול Firebase (רק פעם אחת)
if (!admin.apps.length) {
  admin.initializeApp({
    credential: admin.credential.cert(serviceAccount)
  });
}

const db = admin.firestore();

// ✅ בדיקת חיבור
router.get('/test', (req, res) => {
  res.json({ ok: true, msg: 'twilio route works' });
});

// 📩 קבלת הודעות מוואטסאפ
router.post('/incoming-wa', async (req, res) => {
  try {
    const from = req.body?.From || '';
    const body = req.body?.Body || '';

    console.log('📩 Incoming:', from, body);

    // 🔥 שמירה ב-Firebase
    await db.collection('leads').add({
      phone: from,
      message: body,
      createdAt: new Date()
    });

    console.log('✅ Saved to Firebase');

    // תשובה ל-Twilio
    res.set('Content-Type', 'text/xml');
    res.send('<Response></Response>');

  } catch (error) {
    console.error('❌ Firebase error:', error);
    res.status(500).send('Error');
  }
});

module.exports = router;
